# Frontend Environment Variables

# API
REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENV=development

# Features
REACT_APP_ENABLE_LOGGING=true
REACT_APP_ENABLE_ANALYTICS=false


# 2️⃣ Recommended production server specs
# Minimum (will work)
# CPU: 4 cores
# RAM: 16 GB
# Disk: 500 GB SSD
# Network: 1 Gbps LAN

# Good for 500 internal users.

# Recommended (better)
# CPU: 8 cores
# RAM: 32 GB
# Disk: 1 TB NVMe SSD
# Network: 1 Gbps LAN

# This gives you:

# faster DB queries

# room for growth

# safer performance
# CPU: 8 core
# RAM: 32 GB
# Storage:
#    1 TB NVMe SSD (database)
#    500 GB SSD (uploads)
# Network: 1 Gbps
# OS: Windows Server 2019/2022